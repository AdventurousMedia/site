---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<span class:list={["eyebrow", className]}>
  <slot />
</span>

<style>
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-2);
    line-height: 1;
    display: inline-block;
  }
</style>
