---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Container from "../../components/Container.astro";
import Section from "../../components/Section.astro";
import MarkRule from "../../components/MarkRule.astro";
import Eyebrow from "../../components/Eyebrow.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft)) ?? [];
notes.sort((a, b) => new Date(b.data.dated).getTime() - new Date(a.data.dated).getTime());
---

<Base title="Notes — Adventurous">
  <Header current="/notes" />

  <main>
    <Section size="lg">
      <Container width="prose">
        <div class="page-hero">
          <Eyebrow>Notes</Eyebrow>
          <h1>Working notes from inside the practice.</h1>
          <MarkRule width="short" />
          <p class="sub">
            Short essays on Communications Architecture, executive voice, and the operating layer beneath enterprise comms. Posted irregularly, never to a calendar.
          </p>
        </div>

        {notes.length === 0 ? (
          <div class="empty">
            <p>First note publishing shortly.</p>
          </div>
        ) : (
          <ol class="notes-list">
            {notes.map((note) => (
              <li class="note-item">
                <a href={`/notes/${note.id}`}>
                  <time datetime={note.data.dated.toISOString()} class="note-date">
                    {note.data.dated.toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "numeric" })}
                  </time>
                  <h2 class="note-title">{note.data.title}</h2>
                  <p class="note-summary">{note.data.summary}</p>
                </a>
              </li>
            ))}
          </ol>
        )}
      </Container>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  .page-hero {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 64px;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0;
  }
  .sub {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
  }
  .empty {
    padding-top: 32px;
    border-top: 1px solid var(--hairline);
    color: var(--fg-2);
  }
  .empty p {
    font-family: var(--font-sans);
    font-size: 17px;
    margin: 0;
  }
  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .note-item {
    border-top: 1px solid var(--hairline);
    padding: 24px 0;
  }
  .note-item:last-child {
    border-bottom: 1px solid var(--hairline);
  }
  .note-item a {
    text-decoration: none;
    color: var(--fg);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .note-date {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--fg-2);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .note-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .note-summary {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
  }
  .note-item a:hover .note-title {
    color: var(--mark);
  }
</style>
