---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Container from "../../components/Container.astro";
import Section from "../../components/Section.astro";
import MarkRule from "../../components/MarkRule.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import CTA from "../../components/CTA.astro";

const work = await getCollection("work", ({ data }) => !data.draft);
work.sort((a, b) => a.data.client.localeCompare(b.data.client));
---

<Base title="Work — Adventurous">
  <Header current="/work" />

  <main>
    <Section size="lg">
      <Container>
        <div class="page-hero">
          <Eyebrow>Work</Eyebrow>
          <h1>Two long-running engagements. One discipline.</h1>
          <p class="sub">
            Both engagements began as a content brief and evolved into the operating layer underneath. Both have survived a leadership transition.
          </p>
        </div>
      </Container>
    </Section>

    <Section size="md">
      <Container>
        <ol class="work-list">
          {work.map((entry) => (
            <li class="work-item">
              <a href={`/work/${entry.id}`} class="work-link">
                <div class="work-meta">
                  <Eyebrow>{entry.data.sector}</Eyebrow>
                </div>
                <h2 class="work-client">{entry.data.client}</h2>
                <MarkRule width="short" />
                <p class="work-engagement">{entry.data.engagement}</p>
                <p class="work-summary">{entry.data.summary}</p>
                <p class="work-cta">Read the architecture &rarr;</p>
              </a>
            </li>
          ))}
        </ol>
      </Container>
    </Section>

    <Section size="md" bg="subtle">
      <Container>
        <CTA />
      </Container>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  .page-hero {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 5.5vw, 80px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }
  .sub {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
    max-width: 56ch;
  }
  .work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }
  .work-item {
    border-top: 1px solid var(--hairline);
    padding-top: 32px;
  }
  .work-link {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-decoration: none;
    color: var(--fg);
  }
  .work-client {
    font-family: var(--font-display);
    font-size: clamp(42px, 5vw, 60px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }
  .work-engagement {
    font-family: var(--font-sans);
    font-size: 17px;
    color: var(--fg);
    margin: 0;
  }
  .work-summary {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.55;
    color: var(--fg-2);
    margin: 0;
    max-width: 48ch;
  }
  .work-cta {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--mark);
    margin: 8px 0 0 0;
  }
  .work-link:hover .work-client {
    color: var(--mark);
  }
  @media (max-width: 768px) {
    .work-list {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
