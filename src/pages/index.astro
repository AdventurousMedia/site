---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Container from "../components/Container.astro";
import Section from "../components/Section.astro";
import MarkRule from "../components/MarkRule.astro";
import Eyebrow from "../components/Eyebrow.astro";
import ProofRow from "../components/ProofRow.astro";
import CTA from "../components/CTA.astro";
---

<Base title="Adventurous — Communications Architecture for enterprise">
  <Header />

  <main>
    <Section size="lg">
      <Container>
        <div class="hero">
          <Eyebrow>Communications Architecture · Zurich</Eyebrow>
          <h1 class="positioning">
            Adventurous doesn&rsquo;t<br />pitch concepts<br />or run campaigns.
          </h1>
          <MarkRule width="long" />
          <p class="sub">
            We build the architecture beneath your comms team — so executive voice compounds, and internal cadence holds.
          </p>
        </div>
      </Container>
    </Section>

    <Section size="md" bg="subtle">
      <Container>
        <ProofRow />
      </Container>
    </Section>

    <Section size="md">
      <Container>
        <div class="grid-two">
          <div class="grid-col">
            <Eyebrow>The operating problem</Eyebrow>
            <p class="lede">
              Most enterprises don&rsquo;t have a comms problem they can solve with another agency. They have a comms operating problem: production scattered across formats, executives who sound different in every channel, internal cadence that resets every quarter, measurement that doesn&rsquo;t connect to anything.
            </p>
          </div>
          <div class="grid-col">
            <Eyebrow>The architecture</Eyebrow>
            <p class="lede">
              Adventurous is the firm that fixes the operating layer. We sit alongside the in-house team — not above, not in place of — and embed the system that turns scattered output into compounding signal.
            </p>
            <p class="prose-link"><a href="/about">Read the longer version &rarr;</a></p>
          </div>
        </div>
      </Container>
    </Section>

    <Section size="md" bg="subtle">
      <Container>
        <CTA />
      </Container>
    </Section>
  </main>

  <Footer />
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .positioning {
    font-family: var(--font-display);
    font-size: clamp(54px, 6.5vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }
  .sub {
    font-family: var(--font-sans);
    font-size: clamp(19px, 1.6vw, 24px);
    line-height: 1.4;
    color: var(--fg-2);
    margin: 0;
    max-width: 56ch;
  }
  .grid-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .grid-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .lede {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg);
    max-width: 56ch;
    margin: 0;
  }
  .prose-link {
    margin-top: 8px;
  }
  .prose-link a {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--mark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  @media (max-width: 768px) {
    .hero {
      max-width: none;
    }
    .grid-two {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
